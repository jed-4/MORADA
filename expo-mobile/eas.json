{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://buildpro4.replit.app"
      }
    },
    "simulator": {
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://buildpro4.replit.app"
      }
    },
    "preview": {
      "distribution": "store",
      "channel": "preview",
      "ios": {
        "buildConfiguration": "Release"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://buildpro4.replit.app",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "production": {
      "channel": "production",
      "ios": {
        "buildConfiguration": "Release"
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://buildpro4.replit.app",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    }
  },
  "submit": {
    "preview": {
      "ios": {
        "appleId": "jed4_@hotmail.com",
        "ascAppId": "6759781255"
      }
    },
    "production": {
      "ios": {
        "appleId": "jed4_@hotmail.com",
        "ascAppId": "6759781255"
      }
    }
  }
}
