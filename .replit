modules = ["nodejs-20", "web", "python-3.11", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules"]

[nix]
channel = "stable-24_05"
packages = ["poppler_utils"]

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5904
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 8083
externalPort = 3000

[[ports]]
localPort = 8084
externalPort = 3002

[[ports]]
localPort = 8085
externalPort = 3003

[[ports]]
localPort = 8086
externalPort = 5000

[[ports]]
localPort = 8087
externalPort = 4200

[[ports]]
localPort = 8088
externalPort = 6000

[env]
PORT = "5000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Expo Mobile"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "tenant-isolation"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "note-title-autosave"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "xero-bill-dedup"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "estimate-pricing"

[[workflows.workflow]]
name = "Expo Mobile"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 8081/tcp 2>/dev/null; sleep 3; cd expo-mobile && EXPO_NO_INTERACTIVE=1 npx expo start --port 8081 --tunnel"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
isCanvasWorkflow = true

[[workflows.workflow]]
name = "tenant-isolation"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "NODE_ENV=test npx tsx server/__tests__/tenant-isolation.test.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "note-title-autosave"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "NODE_ENV=test npx tsx server/__tests__/note-title-autosave.test.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "xero-bill-dedup"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "NODE_ENV=test npx tsx server/__tests__/xero-bill-dedup.test.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "estimate-pricing"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "NODE_ENV=test npx tsx server/__tests__/estimate-pricing.test.ts"

[workflows.workflow.metadata]
isValidation = true

[agent]
integrations = ["javascript_log_in_with_replit:1.0.0", "javascript_database:1.0.0", "javascript_openai_ai_integrations:1.0.0", "google-calendar:1.0.0", "javascript_object_storage:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 90000

[userenv]

[userenv.shared]
VITE_CRISP_WEBSITE_ID = "e3620629-080d-4b1e-88b5-821e2adac0fd"
